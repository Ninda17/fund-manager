# Define the stages in order of execution
stages:
  - install
  - lint
  - test
  - build
  - deploy

# Global variables for the entire pipeline
variables:
  NODE_VERSION: "20"
  MONGODB_VERSION: "7.0"
  DOCKER_DRIVER: overlay2
  DOCKER_TLS_CERTDIR: "/certs"
  DOCKER_IMAGE_BACKEND: registry.gitlab.com/$CI_PROJECT_NAMESPACE/$CI_PROJECT_NAME/vehicle_backend:latest
  DOCKER_IMAGE_FRONTEND: registry.gitlab.com/$CI_PROJECT_NAMESPACE/$CI_PROJECT_NAME/vehicle_frontend:latest
  KUBE_CONTEXT: 12230059/k8s-connection:k8s-connection

# Default configuration for all jobs
default:
  image: node:${NODE_VERSION}-alpine
  before_script:
    - apk add --no-cache git
    - node --version
    - npm --version

#install stage jobs
install_backend:
  stage: install
  script:
    - echo "Installing backend dependencies..."
    - cd backend
    - npm ci 
    - echo "Backend dependencies installed successfully"
  artifacts:
    paths:
      - backend/node_modules/
    expire_in: 1 hour

install_frontend:
  stage: install
  script:
    - echo "Installing frontend dependencies..."
    - cd frontend
    - npm ci
    - echo "Frontend dependencies installed successfully"
  artifacts:
    paths:
      - frontend/node_modules/
    expire_in: 1 hour


#linting jobs
lint_backend:
  stage: lint
  dependencies:
    - install_backend
  script:
    - echo "Linting backend code..."
    - cd backend
    - npm run lint
    - echo "Backend linting completed successfully"
  artifacts:
    reports:
      codequality: backend/eslint-report.json
    paths:
      - backend/eslint-report.json
    expire_in: 1 week
    when: always
  allow_failure: false
   
lint_frontend:
  stage: lint
  dependencies:
    - install_frontend
  script:
    - echo "Linting frontend code..."
    - cd frontend
    - echo "Checking if ESLint is available..."
    - npx eslint --version || echo "ESLint not found, installing..."
    - npm run lint
    - echo "Frontend linting completed successfully"
  artifacts:
    reports:
      codequality: frontend/eslint-report.json
    paths:
      - frontend/eslint-report.json
    expire_in: 1 week
    when: always
  allow_failure: false
  

#test jobs
test_backend_unit:
  stage: test
  dependencies:
    - install_backend
  script:
    - echo "Running backend unit tests..."
    - cd backend
    - npm run test:unit -- --coverage --coverageDirectory=coverage
    - echo "Unit test successfully completed"
  artifacts:
    paths:
      - backend/coverage/
    expire_in: 1 week
    when: always
  allow_failure: false
  coverage: '/Lines\s*:\s*(\d+\.\d+)%/'

test_backend_integration:
  stage: test
  dependencies:
    - install_backend
  services:
    - name: mongo:${MONGODB_VERSION}
      alias: mongo
  variables:
    MONGO_URL: "mongodb://mongo:27017/vehicle-maintenance-test"
    TEST_MONGO_URL: "mongodb://mongo:27017/vehicle-maintenance-test"
    JWT_SECRET: "test-jwt-secret-key-for-ci"
    NODE_ENV: "test"
  script:
    - echo "Waiting for MongoDB to be ready..."
    - apk add --no-cache mongodb-tools netcat-openbsd || true
    - |
      echo "Checking MongoDB connection..."
      for i in {1..30}; do
        if nc -z mongo 27017; then
          echo "MongoDB is ready!"
          break
        fi
        echo "Waiting for MongoDB... ($i/30)"
        sleep 1
      done
    - echo "Running backend integration tests..."
    - cd backend
    - npm run test:integration -- --coverage --coverageDirectory=coverage
    - echo "Integration test successfully completed"
  artifacts:
    paths:
      - backend/coverage/
    expire_in: 1 week
    when: always
  allow_failure: false
  coverage: '/Lines\s*:\s*(\d+\.\d+)%/'

test_frontend_unit:
  stage: test
  dependencies:
    - install_frontend
  script:
    - echo "Running frontend unit tests..."
    - cd frontend
    - npm run test:unit -- --coverage
    - echo "Frontend unit tests completed successfully"
  artifacts:
    paths:
      - frontend/coverage/
    expire_in: 1 week
    when: always
  allow_failure: false
  coverage: '/Lines\s*:\s*(\d+\.\d+)%/'


#build jobs
build_backend:
  stage: build
  dependencies:
    - install_backend
  script:
    - echo "Building backend application..."
    - cd backend
    - echo "Checking backend dependencies..."
    - npm list --depth=0
    - echo "Validating backend package.json..."
    - node -e "console.log('Package validation:', JSON.parse(require('fs').readFileSync('package.json', 'utf8')).name)"
    - echo "Creating production-ready backend..."
    - echo "Backend build completed successfully"
    - echo "Backend is ready for deployment"
  artifacts:
    paths:
      - backend/
    exclude:
      - backend/node_modules/
      - backend/.env*
      - backend/*.log
    expire_in: 1 week
  allow_failure: false

build_frontend:
  stage: build
  dependencies:
    - install_frontend
  script:
    - echo "Building frontend application..."
    - cd frontend
    - echo "Checking frontend dependencies..."
    - npm list --depth=0
    - echo "Running frontend build process..."
    - npm run build   #builds a production ready build
    - echo "GENERATING build env file for artifact consumers..."
    - echo "BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)" > .env.build
    - echo "BUILD_COMMIT=${CI_COMMIT_SHORT_SHA:-unknown}" >> .env.build
    - echo "BUILD_PIPELINE_ID=${CI_PIPELINE_ID:-unknown}" >> .env.build
    - echo "Verifying build output..."
    - ls -la dist/
    - echo "Frontend build completed successfully"
    - echo "Build size analysis:"
    - du -sh dist/ #size 
  artifacts:
    paths:
      - frontend/dist/
    expire_in: 1 week
    reports:
      dotenv: frontend/.env.build
  allow_failure: false


docker_build:
  image: docker
  stage: build
  dependencies:
    - build_backend
    - build_frontend
  services:
    - docker:dind
  variables:
    DOCKER_HOST: tcp://docker:2376
    DOCKER_TLS_CERTDIR: "/certs"
  before_script:
    - until docker info; do sleep 1; done
  script:
    - echo "Building and pushing backend Docker image..."
    - echo $CI_REGISTRY_PASSWORD | docker login -u $CI_REGISTRY_USER --password-stdin $CI_REGISTRY

    # Build and push backend
    - cd backend
    - docker build -t $DOCKER_IMAGE_BACKEND .
    - docker push $DOCKER_IMAGE_BACKEND
    - cd ..

    # Build and push frontend
    - cd frontend 
    - docker build -t $DOCKER_IMAGE_FRONTEND .
    - docker push $DOCKER_IMAGE_FRONTEND
    - cd ..

    - echo "Images built successfully"
  allow_failure: false


deploy:
  stage: deploy
  image:
    name: bitnami/kubectl:latest
    entrypoint: ['']
  before_script: []
  variables:
    # This tells GitLab CI to use the agent instead of a local kubeconfig
    GITLAB_KUBE_AGENT: "k8s-connection"
  script:
    - echo "Using GitLab Agent to connect..."
    - kubectl version --client
    - kubectl get nodes
    - kubectl apply -f k8s/
    - kubectl get pods
    - kubectl get svc
  when: manual